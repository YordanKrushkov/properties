rrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},"D:\\WebProjects\\NewProps\\properties\\src\\index.js",[],["93","94"],"D:\\WebProjects\\NewProps\\properties\\src\\reportWebVitals.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\App.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\useState.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\Context.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\form\\post.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\login\\index.js",["95"],"import React, { useState, useContext } from 'react';\r\nimport styles from './index.module.css'\r\nimport { Link, useHistory } from 'react-router-dom'\r\nimport UserContext from '../../Context';\r\nconst apiKey = 'AIzaSyBFr1QW_fF9sluMRPfYk6UzMgoOAxlFC0I'\r\nconst url = `https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=${apiKey}`\r\n\r\nconst Login = () => {\r\n    const [user, getUser] = useState({\r\n        email: '',\r\n        password: ''\r\n    })\r\n    const context = useContext(UserContext);\r\n    const history = useHistory();\r\n    const chnageHendler = (e) => {\r\n        getUser({\r\n            [e.target.id]: e.target.value\r\n        })\r\n    }\r\n    const submitHandler = (e) => {\r\n        e.preventDefault();\r\n        const { email, password } = user;\r\n\r\n        fetch(url, {\r\n            method: 'POST',\r\n            headers: { 'Content-Type': 'application/json' },\r\n            body: JSON.stringify({ email, password })\r\n        }).then(res => res.json())\r\n            .then(data => {\r\n                context.logIn(data.username, data.email)\r\n                localStorage.setItem(\"user\", data.email)\r\n                document.cookie = `x-auth-token=${data.idToken}`\r\n                history.push('/')\r\n            })\r\n            .catch((e) => {\r\n                console.log(e);\r\n            })\r\n    }\r\n\r\n    return (\r\n        <div className={ styles.container }>\r\n            <h1 className={ styles.name }>Sign in</h1>\r\n            <p>Sign in to save your favourite properties, searches, house prices and more.</p>\r\n            <form action=\"\" className={ styles.formBody } onSubmit={ submitHandler }>\r\n                <label htmlFor=\"email\">Email</label>\r\n                <input type=\"email\" name=\"\" id=\"email\" onChange={ chnageHendler } />\r\n                <label htmlFor=\"password\">Password</label>\r\n                <input type=\"password\" name=\"\" id=\"password\" onChange={ chnageHendler } />\r\n                <button>Login</button>\r\n            </form>\r\n            <a href=\"#\" className={ styles.link }>Forgot your password?</a>\r\n            <div className={ styles.register }>\r\n                <div className={ styles.joinUs }> <p>You don't have an accout yet? </p>\r\n                    <Link to=\"/register\">Join us now</Link>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\nexport default Login","D:\\WebProjects\\NewProps\\properties\\src\\components\\main\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Header\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Rent\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Sell\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Register\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\cards\\card-elemtent.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\cards\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchBar\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\services\\getData.js",["96","97"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\singleCard\\index.js",["98"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\cities.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\index.js",["99"],"import React from 'react';\r\nimport styles from './index.module.css'\r\n\r\nconst SearchOpions = (id,text,placeholder,f,) => {\r\n\r\n\r\n    return <option id={id} value={text} placeholder={placeholder} required>{text}  </option>\r\n\r\n}\r\n\r\nexport default SearchOpions","D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\type.js",["100"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\price.js",["101"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\formElements\\inputs.js",["102"],{"ruleId":"103","replacedBy":"104"},{"ruleId":"105","replacedBy":"106"},{"ruleId":"107","severity":1,"message":"108","line":51,"column":13,"nodeType":"109","endLine":51,"endColumn":51},{"ruleId":"110","severity":1,"message":"111","line":3,"column":1,"nodeType":"112","endLine":31,"endColumn":2},{"ruleId":"113","severity":1,"message":"114","line":21,"column":21,"nodeType":"115","messageId":"116","endLine":21,"endColumn":27},{"ruleId":"117","severity":1,"message":"118","line":6,"column":8,"nodeType":"119","messageId":"120","endLine":6,"endColumn":21},{"ruleId":"117","severity":1,"message":"121","line":2,"column":8,"nodeType":"119","messageId":"120","endLine":2,"endColumn":14},{"ruleId":"110","severity":1,"message":"111","line":4,"column":1,"nodeType":"112","endLine":75,"endColumn":2},{"ruleId":"110","severity":1,"message":"111","line":4,"column":1,"nodeType":"112","endLine":83,"endColumn":2},{"ruleId":"110","severity":1,"message":"111","line":6,"column":1,"nodeType":"112","endLine":29,"endColumn":2},"no-native-reassign",["122"],"no-negated-in-lhs",["123"],"jsx-a11y/anchor-is-valid","The href attribute requires a valid value to be accessible. Provide a valid, navigable address as the href value. If you cannot provide a valid href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/evcohen/eslint-plugin-jsx-a11y/blob/master/docs/rules/anchor-is