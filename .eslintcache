history.push('/')\r\n            })\r\n            .catch((e) => {\r\n                console.log(e);\r\n            })\r\n    }\r\n\r\n    return (\r\n        <div className={ styles.container }>\r\n            <h1 className={ styles.name }>Sign in</h1>\r\n            <p>Sign in to save your favourite properties, searches, house prices and more.</p>\r\n            <form action=\"\" className={ styles.formBody } onSubmit={ submitHandler }>\r\n                <label htmlFor=\"email\">Email</label>\r\n                <input type=\"email\" name=\"\" id=\"email\" onChange={ chnageHendler } />\r\n                <label htmlFor=\"password\">Password</label>\r\n                <input type=\"password\" name=\"\" id=\"password\" onChange={ chnageHendler } />\r\n                <button>Login</button>\r\n            </form>\r\n            <a href=\"#\" className={ styles.link }>Forgot your password?</a>\r\n            <div className={ styles.register }>\r\n                <div className={ styles.joinUs }> <p>You don't have an accout yet? </p>\r\n                    <Link to=\"/register\">Join us now</Link>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\n\r\n\r\nexport default Login","D:\\WebProjects\\NewProps\\properties\\src\\components\\main\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Header\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Rent\\index.js",["69"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Sell\\index.js",["70"],"import React, { Component } from 'react'\r\nimport styles from './index.module.css'\r\nimport CardElement from \"../cards/card-elemtent\";\r\n\r\nclass Sell extends Component {\r\n   \r\n    state = {\r\n        properties: []\r\n    }\r\n    getData = async () => {\r\n        const promise = await fetch('https://properties-3e020-default-rtdb.firebaseio.com/properties.json');\r\n        const properties = await promise.json();\r\n        this.setState({\r\n            properties\r\n        })\r\n\r\n    }\r\n\r\n    renderProperties() {\r\n        let { properties } = this.state\r\n        return Object.keys(properties).map((propertie) => {\r\n            console.log();\r\n            if (properties[propertie].hasOwnProperty('sell')) {\r\n                let item = properties[propertie]\r\n                let key = propertie;\r\n\r\n                return (\r\n\r\n                    CardElement(item, key)\r\n                )\r\n            }\r\n        })\r\n    }\r\n\r\n    componentDidMount() {\r\n        this.getData();\r\n    }\r\n\r\n    render() {\r\n        return (\r\n            <div className={styles.wrapper} >\r\n                {this.renderProperties() }\r\n            </div>\r\n\r\n        )\r\n    }\r\n}\r\n\r\nexport default Sell","D:\\WebProjects\\NewProps\\properties\\src\\components\\Register\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\cards\\card-elemtent.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\cards\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchBar\\index.js",[],{"ruleId":"71","replacedBy":"72"},{"ruleId":"73","replacedBy":"74"},{"ruleId":"75","severity":1,"message":"76","line":9,"column":18,"nodeType":"77","messageId":"78","endLine":9,"endColumn":25},{"ruleId":"79","severity":1,"message":"80","line":51,"column":13,"nodeType":"81","endLine":51,"endColumn":51},{"ruleId":"82","severity":1,"message":"83","line":16,"column":56,"nodeType":"84","messageId":"85","endLine":16,"endColumn":58},{"ruleId":"82","severity":1,"message":"83","line":21,"column":56,"nodeType":"84","messageId":"85","endLine":21,"endColumn":58},"no-native-reassign",["86"],"no-negated-in-lhs",["87"],"no-unused-vars","'getUser' is assigned a value but never used.","Identifier","unusedVar","jsx-a11y/anchor-is-valid","The href attribute requires a valid value to be accessible. Provide a valid, navigable address as the href value. If you cannot provide a 