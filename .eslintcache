arningCount":0,"usedDeprecatedRules":"50"},{"filePath":"90","messages":"91","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"92","messages":"93","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"50"},{"filePath":"94","messages":"95","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"96","usedDeprecatedRules":"50"},{"filePath":"97","messages":"98","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"99","usedDeprecatedRules":"50"},"D:\\WebProjects\\NewProps\\properties\\src\\index.js",[],["100","101"],"D:\\WebProjects\\NewProps\\properties\\src\\reportWebVitals.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\App.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\useState.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\Context.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Header\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\cards\\card-elemtent.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\cards\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\services\\getData.js",["102","103","104","105","106","107","108","109","110","111"],"import CardElement from \"../components/cards/card-elemtent\";\r\n\r\nexport default {\r\n    async getData(getProperties) {\r\n        const promise = await fetch('https://properties-3e020-default-rtdb.firebaseio.com/properties.json');\r\n        const properties = await promise.json();\r\n        getProperties(properties)\r\n    },\r\n    renderProperties(properties, filter, newFilter,type,beds) {\r\n        if (properties) {\r\n            return Object.keys(properties).map((propertie) => {\r\n                let prop=properties[propertie]\r\nif (prop.sellOrRent === filter&& prop.city===newFilter \r\n|| prop.sellOrRent === filter&& prop.type===type && prop.city===newFilter\r\n|| prop.sellOrRent === filter && prop.bedrooms===beds && prop.city===newFilter\r\n|| prop.sellOrRent === filter && prop.bedrooms===beds && prop.city===type) {\r\n                    \r\n                    let item = properties[propertie]\r\n                    let key = propertie;\r\n                    return CardElement(item, key)\r\n                }\r\n                else if (filter === 'HOME') {\r\n                    let item = properties[propertie]\r\n                    let key = propertie;\r\n                    return CardElement(item, key)\r\n                } else {\r\n                    return\r\n                }\r\n            })\r\n        } else {\r\n            return <h1> No data</h1>\r\n        }\r\n    },\r\n \r\n\r\nasync getSingleProp(getProperties, id) {\r\n    const promise = await fetch(`https://properties-3e020-default-rtdb.firebaseio.com/properties/${id}.json`);\r\n    const properties = await promise.json();\r\n    getProperties(properties)\r\n}\r\n}","D:\\WebProjects\\NewProps\\properties\\src\\components\\formElements\\inputs.js",["112"],"import React from 'react'\r\nimport styles from './index.module.css'\r\n\r\n\r\n\r\nexport default {\r\n    InputElements(name, type, placeholder, text, f, req) {\r\n\r\n        return (\r\n            <div className={ styles.inputWrapper }>\r\n                <label className={ styles.inputLabel } htmlFor={ name }>{ text }</label>\r\n                {req ? <input className={ styles.input }  placeholder={ placeholder } type={ type } name={ name } id={ name } onChange={ f } required />\r\n                    : <input className={ styles.input }  placeholder={ placeholder } type={ type } name={ name } id={ name } onChange={ f } /> }\r\n            </div>\r\n        )\r\n    }, ButtonsField(className, type, id, name, text, f, req) {\r\n\r\n        return (\r\n            <div className={ className }>\r\n                {req ? <input className={ styles.inputTick }  required type={ type } name={ name } id={ id } onChange={ f } />\r\n                    : <input className={ styles.inputTick }  type={ type } name={ name } id={ id } onChange={ f } /> }\r\n                <label className={ styles.Label } htmlFor={ id }>{ text }</label>\r\n\r\n            </div>\r\n\r\n        )\r\n    },\r\n\r\n}\r\n","D:\\WebProjects\\NewProps\\properties\\src\\Pages\\DetailsPage\\index.js",["113","114","115"],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\Register\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\login\\index.js",["116","117"],"import React, { useState, useContext } from 'react';\r\nimport styles from './index.module.css'\r\nimport { Link, useHistory } from 'react-router-dom'\r\nimport UserContext from '../../Context';\r\nconst apiKey = 'AIzaSyBFr1QW_fF9sluMRPfYk6UzMgoOAxlFC0I'\r\nconst url = `https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=${apiKey}`\r\n\r\nconst Login = () => {\r\n    const [user, getUser] = useState({\r\n        email: '',\r\n        password: '',\r\n    })\r\n\r\n    const context = useContext(UserContext);\r\n    const history = useHistory();\r\n    const chnageHendler = (e) => {\r\n        getUser({\r\n            ...user,\r\n            [e.target.id]: e.target.value\r\n        })\r\n\r\n    }\r\n    const submitHandler = (e) => {\r\n        e.preventDefault();\r\n        const { email, password } = user;\r\n\r\n        fetch(url, {\r\n            method: 'POST',\r\n            headers: { 'Content-Type': 'application/json' },\r\n            body: JSON.stringify({ email, password })\r\n        })\r\n            .then(res => res.json())\r\n            .then((data) => {\r\n                if (data.email) {\r\n                    context.logIn(data.email);\r\n                    localStorage.setItem(\"user\", data.email);\r\n\r\n                }\r\n                document.cookie = `x-auth-token=${data.idToken}`\r\n                history.push('/');\r\n            }).catch((e) => {\r\n                console.log(e);\r\n                history.push('/login')\r\n            })\r\n    }\r\n    return (\r\n        <div className={ styles.container }>\r\n            <h1 className={ styles.name }>Sign in</h1>\r\n            <p  className={styles.p}>Sign in to save your favourite properties, searches, house prices and more.</p>\r\n            <form action=\"\" className={ styles.formBody } onSubmit={ submitHandler }>\r\n                <label htmlFor=\"email\"  className={styles.label}>Email</label>\r\n                <input type=\"email\" name=\"\" id=\"email\"  className={styles.input} onChange={ chnageHendler } />\r\n                <label htmlFor=\"password\"  className={styles.label}>Password</label>\r\n                <input type=\"password\" name=\"\" id=\"password\"   className={styles.input} onChange={ chnageHendler } />\r\n                <button className={styles.button}>Login</button>\r\n            </form>\r\n            <a href=\"#\" className={ styles.link }>Forgot your password?</a>\r\n            <div className={ styles.register }>\r\n                <div className={ styles.joinUs }> <p  className={styles.p}>You don't have an accout yet? </p>\r\n                    <Link  className={styles.joninUs} to=\"/register\" className={ styles.a }>Join us now</Link>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\nexport default Login","D:\\WebProjects\\NewProps\\properties\\src\\Pages\\Rent\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\HomePage\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\Sell\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\SubmitForm\\post.js",["118"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\detailsComponent\\index.js",["119"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\cities.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\type.js",["120"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\price.js",["121"],"import React from 'react'\r\n\r\n\r\nexport default {\r\n\r\n\r\n    SellingPrice(minOrMax, classNeme, f) {\r\n\r\n        return (\r\n            <select name=\"price\" id={ minOrMax }  className={ classNeme } onChange={f}>\r\n                <option value=\"0\" selected>Alll</option>\r\n                <option value=\"10 000\">10 000</option>\r\n                <option value=\"20 000\">20 000</option>\r\n                <option value=\"30 000\">30 000</option>\r\n                <option value=\"40 000\">40 000</option>\r\n                <option value=\"50 000\">50 000</option>\r\n                <option value=\"60 000\">60 000</option>\r\n                <option value=\"70 000\">70 000</option>\r\n                <option value=\"80 000\">80 000</option>\r\n                <option value=\"90 000\">90 000</option>\r\n                <option value=\"100 000\">100 00</option>\r\n                <option value=\"110 000\">110 00</option>\r\n                <option value=\"120 000\">120 00</option>\r\n                <option value=\"130 000\">130 00</option>\r\n                <option value=\"140 000\">140 00</option>\r\n                <option value=\"150 000\">150 00</option>\r\n                <option value=\"160 000\">160 00</option>\r\n                <option value=\"200 000\">200 00</option>\r\n                <option value=\"210 000\">210 00</option>\r\n                <option value=\"220 000\">220 00</option>\r\n                <option value=\"230 000\">230 00</option>\r\n                <option value=\"240 000\">240 00</option>\r\n                <option value=\"250 000\">250 00</option>\r\n                <option value=\"260 000\">260 00</option>\r\n                <option value=\"270 000\">270 00</option>\r\n                <option value=\"280 000\">280 00</option>\r\n                <option value=\"290 000\">290 00</option>\r\n                <option value=\"350 000\">350 00</option>\r\n                <option value=\"400 000\">400 00</option>\r\n                <option value=\"450 000\">450 00</option>\r\n                <option value=\"500 000\">500 00</option>\r\n                <option value=\"550 000\">550 00</option>\r\n                <option value=\"550 000+\">550 00+</option>\r\n            </select>\r\n        )\r\n    },\r\n    RentingPrice(minOrMax, classNeme, f) {\r\n\r\n        return (\r\n            <select name=\"price\" id={ minOrMax } className={ classNeme } onChange={f}>\r\n                <option value=\"0\" selected>Alll</option>\r\n                <option value=\"100\">100</option>\r\n                <option value=\"200\">200</option>\r\n                <option value=\"300\">300</option>\r\n                <option value=\"400\">400</option>\r\n                <option value=\"500\">500</option>\r\n                <option value=\"600\">600</option>\r\n                <option value=\"700\">700</option>\r\n                <option value=\"800\">800</option>\r\n                <option value=\"900\">900</option>\r\n                <option value=\"1000\">1000</option>\r\n                <option value=\"1100\">1100</option>\r\n                <option value=\"1200\">1200</option>\r\n                <option value=\"1300\">1300</option>\r\n                <option value=\"1400\">1400</option>\r\n                <option value=\"1500\">1500</option>\r\n                <option value=\"1600\">1600</option>\r\n                <option value=\"2000\">2000</option>\r\n                <option value=\"2100\">2100</option>\r\n                <option value=\"2200\">2200</option>\r\n                <option value=\"2300\">2300</option>\r\n                <option value=\"2400\">2400</option>\r\n                <option value=\"2500\">2500</option>\r\n                <option value=\"2600\">2600</option>\r\n                <option value=\"2700\">2700</option>\r\n                <option value=\"2800\">2800</option>\r\n                <option value=\"2900\">2900</option>\r\n                <option value=\"3000\">3000</option>\r\n            </select>\r\n        )\r\n    }\r\n\r\n}\r\n\r\n","D:\\WebProjects\\NewProps\\properties\\src\\components\\searchBar\\index.js",["122","123"],"import React, { useState, useEffect, useContext } from 'react'\r\nimport { useHistory } from 'react-router-dom'\r\nimport styles from './index.module.css'\r\nimport AllCities from '../searchInputs/cities'\r\nimport Price from '../searchInputs/price'\r\nimport inputs from '../searchInputs/type'\r\nimport get from '../../services/getData'\r\n\r\nconst Search = () => {\r\n    const [way, changeOption] = useState('RENT');\r\n    const [style, changeStyle] = useState(true);\r\n    const [properties, takeProperties] = useState([]);\r\n    const [search, changeSearch] = useState({})\r\n    const history = useHistory()\r\n    useEffect(() => {\r\n        get.getData(takeProperties);\r\n    }, [])\r\n    const clickHendler = (e) => {\r\n        changeOption(e.target.textContent)\r\n        if (e.target.textContent === 'SALE') {\r\n            changeStyle(false)\r\n        } else {\r\n            changeStyle(true)\r\n        }\r\n    };\r\n\r\n    const changeHandler = (e) => {\r\n        changeSearch({\r\n            ...search,\r\n            [e.target.id]: e.target.value\r\n        })\r\n\r\n    }\r\n\r\n    useEffect(() => {\r\n\r\n    }, [changeHandler])\r\n\r\n    const searchIt = (e) => {\r\n        e.preventDefault()\r\n        history.push('/search')\r\n   \r\n\r\n    }\r\n    return (\r\n        <form action=\"\" onSubmit={ searchIt }>\r\n            <div className={ styles.card }>\r\n                <header className={ styles.header }>\r\n                    <ul className={ styles.headerContainer }>\r\n                        <li onClick={ clickHendler } value='RENT' className={ style ? styles.new : styles.sellOrRent }>RENT</li>\r\n                        <li onClick={ clickHendler } value='SELL' className={ style ? styles.sellOrRent : styles.new }>SALE</li>\r\n                    </ul>\r\n                </header>\r\n                <main className={ styles.main }>\r\n                    <h4 className={ styles.searchCardTitle }> Search for Property </h4>\r\n                    <div className={ styles.imputs } >\r\n                        <label htmlFor=\"town\">Town</label>\r\n                        { AllCities(styles.options, changeHandler) }\r\n                    </div>\r\n\r\n                    { way === \"RENT\" ? (<div className={ styles.imputs } >\r\n                        <label htmlFor=\"price\">Min.Price</label>\r\n                        {Price.RentingPrice(\"minPrice\", styles.options, changeHandler) } </div>) :\r\n                        (<div className={ styles.imputs } >\r\n                            <label htmlFor=\"price\">Min.Price</label>\r\n                            {Price.SellingPrice(\"minPrice\", styles.options, changeHandler) } </div>) }\r\n\r\n                    { way === \"RENT\" ? (<div className={ styles.imputs } >\r\n                        <label htmlFor=\"price\">Max.Price</label>\r\n                        {Price.RentingPrice(\"minPrice\", styles.options, changeHandler) } </div>) :\r\n                        (<div className={ styles.imputs } >\r\n                            <label htmlFor=\"price\">Max.Price</label>\r\n                            {Price.SellingPrice(\"maxPrice\", styles.options, changeHandler) } </div>) }\r\n\r\n                    <div className={ styles.typeContainer }>\r\n                        <div className={ styles.type }>\r\n                            <label htmlFor=\"type\">Property Type</label>\r\n                            { inputs.TypeSelect(styles.typeflat, changeHandler) }\r\n                        </div>\r\n\r\n                        <div className={ styles.type }>\r\n                            <label htmlFor=\"type\">Bedroom</label>\r\n                            { inputs.bedroomCount(styles.typeflat, changeHandler) }\r\n                        </div>\r\n                    </div>\r\n\r\n                </main>\r\n                <button>SEARCH</button>\r\n            </div>\r\n            {get.renderProperties(properties) }\r\n        </form>\r\n    )\r\n}\r\nexport default Search;",{"ruleId":"124","replacedBy":"125"},{"ruleId":"126","replacedBy":"127"},{"ruleId":"128","severity":1,"message":"129","line":3,"column":1,"nodeType":"130","endLine":41,"endColumn":2},{"ruleId":"131","severity":1,"message":"132","line":13,"column":31,"nodeType":"133","messageId":"134","endLine":13,"endColumn":33},{"ruleId":"131","severity":1,"message":"132","line":14,"column":1,"nodeType":"133","messageId":"134","endLine":14,"endColumn":3},{"ruleId":"131","severity":1,"message":"135","line":14,"column":1,"nodeType":"133","messageId":"134","endLine":14,"endColumn":3},{"ruleId":"131","severity":1,"message":"135","line":14,"column":50,"nodeType":"133","messageId":"134","endLine":14,"endColumn":52},{"ruleId":"131","severity":1,"message":"135","line":15,"column":1,"nodeType":"133","messageId":"134","endLine":15,"endColumn":3},{"ruleId":"131","severity":1,"message":"135","line":15,"column":55,"nodeType":"133","messageId":"134","endLine":15,"endColumn":57},{"ruleId":"131","severity":1,"message":"135","line":16,"column":1,"nodeType":"133","messageId":"134","endLine":16,"endColumn":3},{"ruleId":"131","severity":1,"message":"135","line":16,"column":55,"nodeType":"133","messageId":"134","endLine":16,"endColumn":57},{"ruleId":"136","severity":1,"message":"137","line":27,"column":21,"nodeType":"138","messageId":"139","endLine":27,"endColumn":27},{"ruleId":"128","severity":1,"message":"129","line":6,"column":1,"nodeType":"130","endLine":29,"endColumn":2},{"ruleId":"140","severity":1,"message":"141","line":12,"column":8,"nodeType":"142","endLine":12,"endColumn":10,"suggestions":"143"},{"ruleId":"144","severity":1,"message":"145","line":17,"column":9,"nodeType":"146","messag