 }\r\n    const submitHandler = (e) => {\r\n        e.preventDefault();\r\n        const { email, password } = user;\r\n\r\n        fetch(url, {\r\n            method: 'POST',\r\n            headers: { 'Content-Type': 'application/json' },\r\n            body: JSON.stringify({ email, password })\r\n        }).then(res => res.json())\r\n            .then(data => {\r\n                context.logIn(data.username, data.email)\r\n                localStorage.setItem(\"user\", data.email)\r\n                document.cookie = `x-auth-token=${data.idToken}`\r\n                history.push('/')\r\n            })\r\n            .catch((e) => {\r\n                console.log(e);\r\n            })\r\n    }\r\n\r\n    return (\r\n        <div className={ styles.container }>\r\n            <h1 className={ styles.name }>Sign in</h1>\r\n            <p>Sign in to save your favourite properties, searches, house prices and more.</p>\r\n            <form action=\"\" className={ styles.formBody } onSubmit={ submitHandler }>\r\n                <label htmlFor=\"email\">Email</label>\r\n                <input type=\"email\" name=\"\" id=\"email\" onChange={ chnageHendler } />\r\n                <label htmlFor=\"password\">Password</label>\r\n                <input type=\"password\" name=\"\" id=\"password\" onChange={ chnageHendler } />\r\n                <button>Login</button>\r\n            </form>\r\n            <a href=\"#\" className={ styles.link }>Forgot your password?</a>\r\n            <div className={ styles.register }>\r\n                <div className={ styles.joinUs }> <p>You don't have an accout yet? </p>\r\n                    <Link to=\"/register\">Join us now</Link>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\nexport default Login","D:\\WebProjects\\NewProps\\properties\\src\\components\\main\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Header\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Rent\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Sell\\index.js",["77"],"import React, { Component, useState, useEffect } from 'react';\r\nimport styles from './index.module.css';\r\nimport getProperties from '../../services/getData'\r\n\r\nconst Sell = () => {\r\n    const [properties, takeProperties] = useState([]);\r\n\r\n    useEffect(() => {\r\n        getProperties.getData(takeProperties);\r\n    }, [])\r\n\r\n    return (\r\n        <div className={ styles.wrapper } >\r\n            {getProperties.renderProperties(properties, 'sell') }\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default Sell","D:\\WebProjects\\NewProps\\properties\\src\\components\\Register\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\cards\\card-elemtent.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\cards\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchBar\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\services\\getData.js",["78","79","80","81","82"],"import React, { useState, useEffect } from 'react'\r\nimport CardElement from \"../components/cards/card-elemtent\";\r\n\r\nexport default {\r\n     async getData(getProperties){\r\n        const promise = await fetch('https://properties-3e020-default-rtdb.firebaseio.com/properties.json');\r\n        const properties = await promise.json();\r\n        getProperties(properties)\r\n    },\r\n    renderProperties (properties,filter){\r\n        return Object.keys(properties).map((propertie) => {\r\n            if (properties[propertie].hasOwnProperty(filter)) {\r\n                let item = properties[propertie]\r\n                let key = propertie;\r\n                return CardElement(item, key)\r\n            }\r\n        })\r\n    }\r\n}","D:\\WebProjects\\NewProps\\properties\\src\\components\\singleCard\\index.js",["83","84","85","86"],{"ruleId":"87","replacedBy":"88"},{"ruleId":"89","replacedBy":"90"},{"ruleId":"91","sever