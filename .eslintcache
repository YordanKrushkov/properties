"filePath":"62","messages":"63","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"64","messages":"65","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"34"},"D:\\WebProjects\\NewProps\\properties\\src\\index.js",[],["66","67"],"D:\\WebProjects\\NewProps\\properties\\src\\reportWebVitals.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\App.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\useState.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\Context.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\form\\post.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\login\\index.js",["68"],"import React, { Component } from 'react';\r\nimport styles from './index.module.css'\r\nimport { Link } from 'react-router-dom'\r\nimport UserContext from '../../Context';\r\nconst apiKey = 'AIzaSyBFr1QW_fF9sluMRPfYk6UzMgoOAxlFC0I'\r\nconst url=`https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=${apiKey}`\r\nclass Login extends Component {\r\n\r\n    state = {\r\n        email: '',\r\n        password: ''\r\n    }\r\n    static contextType=UserContext;\r\n    chnageHendler = (e) => {\r\n        this.setState({\r\n            [e.target.id]: e.target.value\r\n        })\r\n    }\r\n    submitHandler = (e) => {\r\n        e.preventDefault();\r\n        const { email, password} = this.state;\r\n        \r\n        fetch(url, {\r\n            method: 'POST',\r\n            headers: { 'Content-Type': 'application/json' },\r\n            body: JSON.stringify({email,password})\r\n        }).then(res => res.json())\r\n        .then (data=>{\r\n            this.context.logIn(data.username, data.email)\r\n            localStorage.setItem(\"user\", data.email)\r\n            document.cookie=`x-auth-token=${data.idToken}`\r\n            this.props.history.push('/')\r\n        })\r\n        .catch((e)=>{\r\n            console.log(e);\r\n        })\r\n    }\r\n    render() {\r\n        return (\r\n            <div className={ styles.container }>\r\n                <h1 className={ styles.name }>Sign in</h1>\r\n                <p>Sign in to save your favourite properties, searches, house prices and more.</p>\r\n                <form action=\"\" className={ styles.formBody } onSubmit={this.submitHandler}>\r\n                    <label htmlFor=\"email\">Email</label>\r\n                    <input type=\"email\" name=\"\" id=\"email\" onChange={this.chnageHendler} />\r\n                    <label htmlFor=\"password\">Password</label>\r\n                    <input type=\"password\" name=\"\" id=\"password\" onChange={this.chnageHendler}/>\r\n                    <button>Login</button>\r\n                </form>\r\n                <a href=\"#\" className={ styles.link }>Forgot your password?</a>\r\n                <div className={ styles.register }>\r\n                    <div className={ styles.joinUs }> <p>You don't have an accout yet? </p>\r\n                        <Link to=\"/register\">Join us now</Link> \r\n                    </div>\r\n                </div>\r\n            </div>\r\n        )\r\n    }\r\n}\r\n\r\nexport default Login","D:\\WebProjects\\NewProps\\properties\\src\\components\\main\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Header\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Rent\\index.js",["69"],"import React, { Component } from 'react'\r\nimport styles from './index.module.css'\r\nimport CardElement from \"../cards/card-elemtent\";\r\nimport UserContext from '../../Context';\r\n\r\nclass Rent extends Component {\r\n   \r\n    state = {\r\n        properties: []\r\n    }\r\n    static contextType=UserContext;\r\n    getData = async () => {\r\n        const promise = await fetch('https://properties-3e020-default-rtdb.firebaseio.com/properties.json');\r\n        const properties = await promise.json();\r\n        this.setState({\r\n            properties\r\n        })\r\n\r\n    }\r\n\r\n    renderProperties() {\r\n        let { properties } = this.state\r\n        return Object.keys(properties).map((propertie) => {\r\n            if (properties[propertie].hasOwnProperty('rent')) {\r\n                let item = properties[propertie]\r\n                let key = propertie;\r\n\r\n                return  CardElement(item, key)\r\n                \r\n            }\r\n        })\r\n    }\r\n\r\n    componentDidMount() {\r\n        this.getData();\r\n    }\r\n\r\n    render() {\r\n        return (\r\n            <div className={styles.wrapper} >\r\n                {this.renderProperties() }\r\n            </div>\r\n\r\n        )\r\n    }\r\n}\r\n\r\nexport default Rent","D:\\WebProjects\\NewProps\\properties\\src\\components\\Sell\\index.js",["70"],"import React, { Component } from 'react'\r\nimport styles from './index.module.css'\r\nimport CardElement from \"../cards/card-elemtent\";\r\n\r\nclass Sell extends Component {\r\n   \r\n    state = {\r\n        properties: []\r\n    }\r\n    getData = async () => {\r\n        const promise = await fetch('https://properties-3e020-default-rtdb.firebaseio.com/properties.json');\r\n        const properties = await promise.json();\r\n        this.setState({\r\n            properties\r\n        })\r\n\r\n    }\r\n\r\n    renderProperties() {\r\n        let { properties } = this.state\r\n        return Object.keys(properties).map((propertie) => {\r\n            console.log();\r\n            if (properties[propertie].hasOwnProperty('sell')) {\r\n                let item = properties[propertie]\r\n                let key = propertie;\r\n\r\n                return (\r\n\r\n                    CardElement(item, key)\r\n                )\r\n            }\r\n        })\r\n    }\r\n\r\n    componentDidMount() {\r\n        this.getData();\r\n    }\r\n\r\n    render() {\r\n        return (\r\n            <div className={styles.wrapper} >\r\n                {this.renderProperties() }\r\n            </div>\r\n\r\n        )\r\n    }\r\n}\r\n\r\nexport default Sell","D:\\WebProjects\\NewProps\\properties\\src\\components\\Register\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\cards\\card-elemtent.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\cards\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchBar\\index.js",[],{"ruleId":"71","replacedBy":"72"},{"ruleId":"73","replacedBy":"74"},{"ruleId":"75","severity":1,"message":"76","line":50,"column":17,"nodeType":"77","endLine":50,"endColumn":55},{"ruleId":"78","severity":1,"message":"79","line":23,"column":56,"nodeType":"80","messageId":"81","endLine":23,"endColumn":58},{"ruleId":"78","severity":1,"message":"79","line":21,"column":56,"nodeType":"80","messageId":"81","endLine":21,"endColumn":58},"no-native-reassign",["82"],"no-negated-in-lhs",["83"],"jsx-a11y/anchor-is-valid","The href attribute requires a valid value to be accessible. Provide a valid, navigable address as the href value. If you cannot provide a valid href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/evcohen/eslint-plugin-jsx-a11y/blob/master/docs/rules/anchor-is-valid.md","JSXOpeningElement","array-callback-return","Array.prototype.map() expects a value to be returned at the end of arrow function.","ArrowFunctionExpression","expectedAtEnd","no-global-assign","no-unsafe-negation"]