:\\WebProjects\\NewProps\\properties\\src\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\reportWebVitals.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\App.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\useState.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\Context.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Header\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\cards\\card-elemtent.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\cards\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\services\\getData.js",["208","209"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\formElements\\inputs.js",["210"],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\DetailsPage\\index.js",["211","212"],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\Register\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\login\\index.js",["213","214"],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\Rent\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\HomePage\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\Sell\\index.js",["215","216"],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\SubmitForm\\post.js",["217"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\detailsComponent\\index.js",["218"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\cities.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\type.js",["219"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\price.js",["220"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchBar\\index.js",["221","222"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\filterBar\\filter.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\index.js",[],["223","224"],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\useState.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\reportWebVitals.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\App.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\Context.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\Pages\\SubmitForm\\post.js",["225"],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\Pages\\login\\index.js",["226","227"],"import React, { useState, useContext } from 'react';\nimport styles from './index.module.css'\nimport { Link, useHistory } from 'react-router-dom'\nimport UserContext from '../../Context';\nimport authenticate from '../../services/auth'\nconst url = 'http://localhost:4000/api/login'\n\nconst Login = () => {\n    const [user, getUser] = useState({\n        email: '',\n        password: '',\n    })\n    const context = useContext(UserContext);\n    const history = useHistory();\n    const chnageHendler = (e) => {\n        getUser({\n            ...user,\n            [e.target.id]: e.target.value\n        })\n\n    };\n    const submitHandler = async (e) => {\n        e.preventDefault();\n        const { email, password } = user;\n\n        await authenticate(url, {\n            email, password\n        }, (user) => {\n            console.log(user);\n            context.logIn(user);\n            localStorage.setItem(\"user\", email);\n            history.push('/');\n        }, (e) => {\n            console.log(e);\n            history.push('/login')\n        })\n    };\n    return (\n        <div className={ styles.container }>\n            <h1 className={ styles.name }>Sign in</h1>\n            <p className={ styles.p }>Sign in to save your favourite properties, searches, house prices and more.</p>\n            <form action=\"\" className={ styles.formBody } onSubmit={ submitHandler }>\n                <label htmlFor=\"email\" className={ styles.label }>Email</label>\n                <input type=\"email\" name=\"\" id=\"email\" className={ styles.input } onChange={ chnageHendler } />\n                <label htmlFor=\"password\" className={ styles.label }>Password</label>\n                <input type=\"password\" name=\"\" id=\"password\" className={ styles.input } onChange={ chnageHendler } />\n                <button className={ styles.button }>Login</button>\n            </form>\n            <a href=\"#\" className={ styles.link }>Forgot your password?</a>\n            <div className={ styles.register }>\n                <div className={ styles.joinUs }> <p className={ styles.p }>You don't have an accout yet? </p>\n                    <Link className={ styles.joninUs } to=\"/register\" className={ styles.a }>Join us now</Link>\n                </div>\n            </div>\n        </div>\n    )\n}\nexport default Login","D:\\WebProjects\\NewProps\\properties - Copy\\src\\Pages\\DetailsPage\\index.js",["228","229"],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\Pages\\Rent\\index.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\Pages\\HomePage\\index.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\Pages\\Register\\index.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\Pages\\Sell\\index.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\components\\Header\\index.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\components\\formElements\\inputs.js",["230"],"import React from 'react'\nimport styles from './index.module.css'\n\n\n\nexport default {\n    InputElements(name, type, placeholder, text, f, req) {\n\n        return (\n            <div className={ styles.inputWrapper }>\n                <label className={ styles.inputLabel } htmlFor={ name }>{ text }</label>\n                {req ? <input className={ styles.input }  placeholder={ placeholder } type={ type } name={ name } id={ name } onChange={ f } required />\n                    : <input className={ styles.input }  placeholder={ placeholder } type={ type } name={ name } id={ name } onChange={ f } /> }\n            </div>\n        )\n    }, ButtonsField(className, type, id, name, text, f, req) {\n\n        return (\n            <div className={ className }>\n                {req ? <input className={ styles.inputTick }  required type={ type } name={ name } id={ id } onChange={ f } />\n                    : <input className={ styles.inputTick }  type={ type } name={ name } id={ id } onChange={ f } /> }\n                <label className={ styles.Label } htmlFor={ id }>{ text }</label>\n\n            </div>\n\n        )\n    },\n\n}\n","D:\\WebProjects\\NewProps\\properties - Copy\\src\\components\\searchInputs\\cities.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\components\\searchInputs\\type.js",["231"],"import React from 'react'\nimport SearchOpions from './index'\n\nexport default {\n\n    TypeSelect(className, f) {\n\n        return (\n            <select name=\"type\" id=\"type\" className={ className }  onChange={f} required>\n                <option value=\"0\">Select...</option>\n                { SearchOpions('type',  'Flat', null) }\n                { SearchOpions('type', 'House', null) }\n                { SearchOpions('type', 'Cottage', null) }\n                { SearchOpions('type', 'Land', null) }\n            </select>\n        )\n    },\n\n    bedroomCount(className,f) {\n        return (\n            <select name=\"type\" id=\"bedrooms\" className={ className }  onChange={f} required>\n                <option value=\"0\">Select...</option>\n                { SearchOpions('bedrooms', 'studio', 'Studio', null) }\n                { SearchOpions('bedrooms', '1 bedroom', null) }\n                { SearchOpions('bedrooms', '2 bedroom', null) }\n                { SearchOpions('bedrooms', '3 bedroom',null ) }\n                { SearchOpions('bedrooms', '4 bedroom',null ) }\n            </select>\n        )\n\n    },\n    bathroomCount(className,f) {\n        return (\n            <select name=\"type\" id=\"bathroom\" className={ className }  onChange={f} required>\n                <option value=\"0\">Select...</option>\n                { SearchOpions('bathroom', '1 bathroom', null) }\n                { SearchOpions('bathroom', '2 bathroom', null) }\n                { SearchOpions('bathroom', '3 bathroom',null ) }\n                { SearchOpions('bathroom', '4 bathroom',null ) }\n            </select>\n        )\n\n    },\n    construction(className, f) {\n        return (\n            <select name=\"construction\" id=\"construction\" className={ className } required onChange={f}>\n                <option value=\"0\">Select...</option>\n                { SearchOpions('construction',  'New',null) }\n                { SearchOpions('construction', 'Old',null) }\n                { SearchOpions('construction', 'Brick',null) }\n                { SearchOpions('construction', 'Panel',null) }\n            </select>\n        )\n\n    },\n    floor(className,op,f) {\n        return (\n            <select name=\"floor\" id={\"floor\"+op} className={ className } required onChange={f}>\n                <option value=\"0\">Select...</option>\n                { SearchOpions('floor',  '1',null) }\n                { SearchOpions('floor', '2',null) }\n                { SearchOpions('floor',  '3',null) }\n                { SearchOpions('floor',  '4',null) }\n            </select>\n        )\n    },\n    furniture(className,f) {\n        return (\n            <select name=\"furnished\" id=\"furnished\" className={ className } required onChange={f}>\n                <option value=\"0\">Select...</option>\n                { SearchOpions('furnished', 'Furnished',null) }\n                { SearchOpions('furnished',  'Part-furnished',null) }\n                { SearchOpions('furnished', 'Not furnished',null) }\n            </select>\n        )\n    },\n    heating(className, f) {\n        return (\n            <select name=\"heating\" id=\"heating\" className={ className } required onChange={f}>\n                <option value=\"0\">Select...</option>\n                { SearchOpions('heating', 'Gas', null) }\n                { SearchOpions('heating', 'Electricity', null) }\n                { SearchOpions('heating','Local', null) }\n            </select>\n        )\n    },\n}","D:\\WebProjects\\NewProps\\properties - Copy\\src\\components\\filterBar\\filter.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\services\\getData.js",["232"],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\components\\searchInputs\\index.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\components\\cards\\index.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\components\\searchBar\\index.js",["233","234","235"],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\components\\detailsComponent\\index.js",["236"],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\components\\cards\\card-elemtent.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\components\\searchInputs\\price.js",["237"],"import React from 'react'\n\n\nexport default {\n\n\n    SellingPrice(minOrMax, classNeme, f) {\n\n        return (\n            <select name=\"price\" id={ minOrMax }  className={ classNeme } onChange={f}>\n                <option value=\"0\" selected>Alll</option>\n                <option value=\"10 000\">10 000</option>\n                <option value=\"20 000\">20 000</option>\n                <option value=\"30 000\">30 000</option>\n                <option value=\"40 000\">40 000</option>\n                <option value=\"50 000\">50 000</option>\n                <option value=\"60 000\">60 000</option>\n                <option value=\"70 000\">70 000</option>\n                <option value=\"80 000\">80 000</option>\n                <option value=\"90 000\">90 000</option>\n                <option value=\"100 000\">100 00</option>\n                <option value=\"110 000\">110 00</option>\n                <option value=\"120 000\">120 00</option>\n                <option value=\"130 000\">130 00</option>\n 