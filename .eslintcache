cts\\NewProps\\properties\\src\\App.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\useState.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\Context.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Header\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\cards\\card-elemtent.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\cards\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\services\\getData.js",["206","207"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\formElements\\inputs.js",["208"],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\DetailsPage\\index.js",["209","210"],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\Register\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\login\\index.js",["211","212"],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\Rent\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\HomePage\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\Sell\\index.js",["213","214"],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\SubmitForm\\post.js",["215"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\detailsComponent\\index.js",["216"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\cities.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\type.js",["217"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\price.js",["218"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchBar\\index.js",["219","220"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\filterBar\\filter.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\index.js",[],["221","222"],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\useState.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\reportWebVitals.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\App.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\Context.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\Pages\\SubmitForm\\post.js",["223"],"import React, { useState, useContext } from 'react'\nimport { useHistory } from 'react-router-dom'\nimport styles from './index.module.css'\nimport AllCities from '../../components/searchInputs/cities'\nimport elements from '../../components/formElements/inputs'\nimport inputs from '../../components/searchInputs/type'\nimport UserContext from '../../Context'\nconst PostForm = () => {\n    const context = useContext(UserContext)\n    const [initialState, getState] = useState([])\n    const [properties, getData] = useState({\n        img: '',\n        type: '',\n        price: '',\n        city: '',\n        street: '',\n        bedrooms: '',\n        bathroom: '',\n        construction: '',\n        floorbuilding: '',\n        floormax: '',\n        furnished: '',\n        heating: '',\n        size: '',\n        year: '',\n        sellOrRent: 'RENT',\n        details: initialState,\n        description: '',\n        email: '',\n        name: '',\n        phone: '',\n        floorplan: '',\n    });\n    const [style, changeStyle] = useState(true);\n    const history = useHistory()\n\n    const onChangeHandler = (e) => {\n\n        getData({\n            ...properties,\n            [e.target.id]: e.target.value,\n            email: context.email\n        });\n    };\n    const detailHendler = (e) => {\n\n        if (e.target.checked) {\n            initialState.push(e.target.name)\n        }\n        if (!e.target.checked) {\n            let el = initialState.find(el => (el === e.target.name))\n            let index = initialState.indexOf(el)\n            initialState.splice(index, 1)\n        }\n        console.log(initialState);\n\n    };\n    const submitHandler = async (e) => {\n        e.preventDefault();\n        getData({\n            ...properties,\n            details: initialState,\n        })\n\n        let promise = await fetch('https://properties-3e020-default-rtdb.firebaseio.com/properties.json', {\n            method: 'POST',\n            body: JSON.stringify(properties)\n        })\n        let data = await promise.json();\n        history.push('/');\n        return data;\n\n    };\n    const openWidget = (e) => {\n        e.preventDefault()\n        const widget = window.cloudinary.createUploadWidget({\n            cloudName: \"zltgrd\",\n            uploadPreset: \"properties\"\n        }, (error, result) => {\n            console.log(\"Error\", error);\n            console.log('Succes', result);\n            if (result.event === 'success') {\n                getData({\n                    ...properties,\n                    img: result.info.url\n                })\n            }\n\n        })\n        widget.open()\n    };\n\n    const openWidgetFloorPlan = (e) => {\n        e.preventDefault()\n        const widget = window.cloudinary.createUploadWidget({\n            cloudName: \"zltgrd\",\n            uploadPreset: \"properties\"\n        }, (error, result) => {\n            console.log(\"Error\", error);\n            console.log('Succes', result);\n            if (result.event === 'success') {\n                getData({\n                    ...properties,\n                    floorplan: result.info.url\n                })\n            }\n\n        })\n        widget.open()\n    };\n    const clickHendler = (e) => {\n        if (e.target.textContent === 'SALE') {\n            changeStyle(false)\n            getData({\n                ...properties,\n                sellOrRent: 'SALE'\n            })\n        } else {\n            changeStyle(true);\n            getData({\n                ...properties,\n                sellOrRent: 'RENT'\n            })\n        }\n\n    };\n\n    return (\n        <div className={ styles.formContainer }>\n            <header className={ styles.header }>\n                <ul className={ styles.headerContainer }>\n                    <li onClick={ clickHendler } value='RENT' className={ style ? styles.new : styles.sellOrRent }>RENT</li>\n                    <li onClick={ clickHendler } value='SALE' className={ style ? styles.sellOrRent : styles.new }>SALE</li>\n                </ul>\n            </header>\n            <h2 className={ styles.title }>List your property</h2>\n            <form className={ styles.form } action=\"\" onSubmit={ submitHandler }>\n\n                <div className={ styles.propertieOptions }>\n                    <div className={ styles.optionSection }>\n                        <div className={ styles.typeContainer }>\n                            <h2 className={ styles.h2Label }>Where</h2>\n                            { AllCities(styles.optionMenu, onChangeHandler) }\n                        </div>\n                        <div className={ styles.typeContainer }>\n                            <h2 className={ styles.h2Label }>Property Type</h2>\n                            { inputs.TypeSelect(styles.optionMenu, onChangeHandler) }\n                        </div>\n                        <div className={ styles.typeContainer }>\n                            <h2 className={ styles.h2Label }>Construction</h2>\n                            { inputs.construction(styles.optionMenu, onChangeHandler) }\n                        </div>\n\n                    </div>\n\n                    <div className={ styles.optionSection }>\n                        <div className={ styles.typeContainer }>\n                            <h2 className={ styles.h2Label }>Bedrooms</h2>\n                            { inputs.bedroomCount(styles.optionMenu, onChangeHandler) }\n                        </div>\n                        <div className={ styles.typeContainer }>\n                            <h2 className={ styles.h2Label }>Bathrooms</h2>\n                            { inputs.bathroomCount(styles.optionMenu, onChangeHandler) }\n                        </div>\n\n                        <div className={ styles.typeContainer }>\n                            <h2 className={ styles.h2Label }>Furniture</h2>\n                            { inputs.furniture(styles.optionMenu, onChangeHandler) }\n                        </div>\n                    </div>\n                    <div className={ styles.optionSection }>\n                        <div className={ styles.typeContainer }>\n                            <h2 className={ styles.h2Label }>Floor</h2>\n                            { inputs.floor(styles.optionMenu, 'building', onChangeHandler) }\n                        </div>\n                        <div className={ styles.typeContainer }>\n                            <h2 className={ styles.h2Label }>Total floors</h2>\n                            { inputs.floor(styles.optionMenu, 'max', onChangeHandler) }\n                        </div>\n                        <div className={ styles.typeContainer }>\n                            <h2 className={ styles.h2Label }>Heating</h2>\n                            { inputs.heating(styles.optionMenu, onChangeHandler) }\n                        </div>\n                    </div>\n\n                </div>\n                <div className={ styles.details }>\n                    <div className={ styles.street }>\n                        <label className={ styles.streetLabel } htmlFor=\"street\">Street</label>\n                        <input className={ styles.streetInput } onChange={ onChangeHandler } placeholder=\"e.g. Oxford Str.\" type=\"text\" name='street' id=\"street\" />\n                    </div>\n                    { elements.InputElements('price', 'text', 'e.g. 1500', 'Price', onChangeHandler, 'req') }\n                    { elements.InputElements('size', 'text', 'e.g. 74 sq m', 'Area', onChangeHandler) }\n                </div>\n\n                <div className={ styles.freeDetailsParent }>\n                    <div>\n                        { elements.ButtonsField(styles.type, 'checkbox', 'details', 'Balcony', 'Balcony', detailHendler) }\n                        { elements.ButtonsField(styles.type, 'checkbox', 'details', 'Garden', 'Garden', detailHendler) }\n                        { elements.ButtonsField(styles.type, 'checkbox', 'details', 'Swimming pool', 'Swimming pool', detailHendler) }\n                        { elements.ButtonsField(styles.type, 'checkbox', 'details', 'Easy transport', 'Easy transport', detailHendler) }\n                        { elements.ButtonsField(styles.type, 'checkbox', 'details', 'Lift', 'Lift', detailHendler) }\n                    </div>\n                    <div>\n                        { elements.ButtonsField(styles.type, 'checkbox', 'details', 'Wellcome Pets', 'Wellcome Pets', detailHendler) }\n                        { elements.ButtonsField(styles.type, 'checkbox', 'details', 'Smoking', 'Smoking', detailHendler) }\n                        { elements.ButtonsField(styles.type, 'checkbox', 'details', 'Garage', 'Garage', detailHendler) }\n                        { elements.ButtonsField(styles.type, 'checkbox', 'details', 'Free Parking', 'Free Parking', detailHendler) }\n                        { elements.ButtonsField(styles.type, 'checkbox', 'details', 'Video Security', 'Video Security', detailHendler) }\n                    </div>\n                </div>\n                <div className={ styles.buttonsWrapper }>\n                    <button className={ styles.button } onClick={ openWidget } required>Upload Image</button>\n                    <button className={ styles.button } onClick={ openWidgetFloorPlan }>Upload Floor Plan</button>\n\n                </div>\n\n                <div className={ styles.description }>\n                    <textarea id=\"description\" placeholder='Please, write some description here...' className={ styles.textArea } onChange={ onChangeHandler } />\n                </div>\n\n\n                <button className={ styles.button }>SUMBIT</button>\n            </form>\n        </div>\n    )\n\n\n\n\n}\n\nexport default PostForm;\n\n// {/* {ButtonsField(styles.type,'radio','type','flat', 'Flat','req')}\n//                 {ButtonsField(styles.type,'radio','type','house', 'House')}\n//                 {ButtonsField(styles.type,'radio','type','cottage', 'Cottage')}\n//                 {ButtonsField(styles.type,'radio','type','land', 'Land')} */}\n\n// {/* {ButtonsField(styles.type,'radio','bedroom','studio', 'Studio','req')}\n//                 {ButtonsField(styles.type,'radio','bedroom','one', '1 bedroom')}\n//                 {ButtonsField(styles.type,'radio','bedroom','two', '2 bedroom')}\n//                 {ButtonsField(styles.type,'radio','bedroom','three', '3 bedroom')}\n//                 {ButtonsField(styles.type,'radio','bedroom','four', '4 bedroom +')} */}","D:\\WebProjects\\NewProps\\properties - Copy\\src\\Pages\\login\\index.js",["224","225"],"import React, { useState, useContext } from 'react';\nimport styles from './index.module.css'\nimport { Link, useHistory } from 'react-router-dom'\nimport UserContext from '../../Context';\nimport authenticate from '../../services/auth'\nconst url = 'http://localhost:4000/api/login'\n\nconst Login = () => {\n    const [user, getUser] = useState({\n        email: '',\n        password: '',\n    })\n    const context = useContext(UserContext);\n    const history = useHistory();\n    const chnageHendler = (e) => {\n        getUser({\n            ...user,\n            [e.target.id]: e.target.value\n        })\n\n    };\n    const submitHandler = async (e) => {\n        e.preventDefault();\n        const { email, password } = user;\n\n        await authenticate(url, {\n            email, password\n        }, (user) => {\n            console.log(user);\n            context.logIn(user);\n            localStorage.setItem(\"user\", email);\n            history.push('/');\n        }, (e) => {\n            console.log(e);\n            history.push('/login')\n        })\n    };\n    return (\n        <div className={ styles.container }>\n            <h1 className={ styles.name }>Sign in</h1>\n            <p className={ styles.p }>Sign in to save your favourite properties, searches, house prices and more.</p>\n            <form action=\"\" className={ styles.formBody } onSubmit={ submitHandler }>\n                <label htmlFor=\"email\" className={ styles.label }>Email</label>\n                <input type=\"email\" name=\"\" id=\"email\" className={ styles.input } onChange={ chnageHendler } />\n                <label htmlFor=\"password\" className={ styles.label }>Password</label>\n                <input type=\"password\" name=\"\" id=\"password\" className={ styles.input } onChange={ chnageHendler } />\n                <button className={ styles.button }>Login</button>\n            </form>\n            <a href=\"#\" className={ styles.link }>Forgot your password?</a>\n            <div className={ styles.register }>\n                <div className={ styles.joinUs }> <p className={ styles.p }>You don't have an accout yet? </p>\n                    <Link className={ styles.joninUs } to=\"/register\" className={ styles.a }>Join us now</Link>\n                </div>\n            </div>\n        </div>\n    )\n}\nexport default Login","D:\\WebProjects\\NewProps\\properties - Copy\\src\\Pages\\DetailsPage\\index.js",["226","227"],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\Pages\\Rent\\index.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\Pages\\HomePage\\index.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\Pages\\Register\\index.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\Pages\\Sell\\index.js",["228","229"],"import React, {useState, useEffect } from 'react';\nimport styles from './index.module.css';\nimport getProperties from '../../services/getData'\nimport theType from '../../components/searchInputs/type'\nimport AllCities from '../../components/searchInputs/cities'\nimport Filter from '../../components/filterBar/filter'\n\n\nconst Sell = () => {\n    const [properties, takeProperties] = useState([]);\n    const [filter, getFilter]=useState({\n        city:'',\n        type:'',\n        bedrooms:''\n    })\n\n\n    useEffect(() => {\n        getProperties.getData(takeProperties);\n    }, []);\n    const ChangeHandler=(e)=>{\n        getFilter({\n            ...filter,\n            [e.target.id]:e.target.value\n        })\n    }\n    const showProp = (e) => {\n        document.getElementById('filterBar').style.display = 'flex';\n    }\n\n    return (\n        <div className={ styles.containerWrapper }>\n            {Filter(ChangeHandler)}\n            <div className={ styles.container } onMouseOver={ showProp }>\n            \n\n                <div className={ styles.wrapper } >\n                    { getProperties.renderProperties(properties, 'SALE', !filter.city ? 'София' : filter.city, filter.type) }\n                </div>\n                <aside className={ styles.aside }>\n                <div className={ styles.assideWrapper }></div>\n            </aside>\n            </div>\n         \n\n        </div>\n\n    )\n}\n\nexport default Sell","D:\\WebProjects\\NewProps\\properties - Copy\\src\\components\\Header\\index.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\components\\formElements\\inputs.js",["230"],"import React from 'react'\nimport styles from './index.module.css'\n\n\n\nexport default {\n    InputElements(name, type, placeholder, text, f, req) {\n\n        return (\n            <div className={ styles.inputWrapper }>\n                <label className={ styles.inputLabel } htmlFor={ name }>{ text }</label>\n                {req ? <input className={ styles.input }  placeholder={ placeholder } type={ type } name={ name } id={ name } onChange={ f } required />\n                    : <input className={ styles.input }  placeholder={ placeholder } type={ type } name={ name } id={ name } onChange={ f } /> }\n            </div>\n        )\n    }, ButtonsField(className, type, id, name, text, f, req) {\n\n        return (\n            <div className={ className }>\n                {req ? <input className={ styles.inputTick }  required type={ type } name={ name } id={ id } onChange={ f } />\n                    : <input className={ styles.inputTick }  type={ type } name={ name } id={ id } onChange={ f } /> }\n                <label className={ styles.Label } htmlFor={ id }>{ text }</label>\n\n            </div>\n\n        )\n    },\n\n}\n","D:\\WebProjects\\NewProps\\properties - Copy\\src\\components\\searchInputs\\cities.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\components\\searchInputs\\type.js",["231"],"import React from 'react'\nimport SearchOpions from './index'\n\nexport default {\n\n    TypeSelect(className, f) {\n\n        return (\n            <select name=\"type\" id=\"type\" className={ className }  onChange={f} required>\n                <option value=\"0\">Select...</option>\n                { SearchOpions('type',  'Flat', null) }\n                { SearchOpions('type', 'House', null) }\n                { SearchOpions('type', 'Cottage', null) }\n                { SearchOpions('type', 'Land', null) }\n            </select>\n        )\n    },\n\n    bedroomCount(className,f) {\n        return (\n            <select name=\"type\" id=\"bedrooms\" className={ className }  onChange={f} required>\n                <option value=\"0\">Select...</option>\n                { SearchOpions('bedrooms', 'studio', 'Studio', null) }\n                { SearchOpions('bedrooms', '1 bedroom', null) }\n                { SearchOpions('bedrooms', '2 bedroom', null) }\n                { SearchOpions('bedrooms', '3 bedroom',null ) }\n                { SearchOpions('bedrooms', '4 bedroom',null ) }\n            </select>\n        )\n\n    },\n    bathroomCount(className,f) {\n        return (\n            <select name=\"type\" id=\"bathroom\" className={ className }  onChange={f} required>\n                <option value=\"0\">Select...</option>\n                { SearchOpions('bathroom', '1 bathroom', null) }\n                { SearchOpions('bathroom', '2 bathroom', null) }\n                { SearchOpions('bathroom', '3 bathroom',null ) }\n                { SearchOpions('bathroom', '4 bathroom',null ) }\n            </select>\n        )\n\n    },\n    construction(className, f) {\n        return (\n            <select name=\"construction\" id=\"construction\" className={ className } required onChange={f}>\n                <option value=\"0\">Select...</option>\n                { SearchOpions('construction',  'New',null) }\n                { SearchOpions('construction', 'Old',null) }\n                { SearchOpions('construction', 'Brick',null) }\n                { SearchOpions('construction', 'Panel',null) }\n            </select>\n        )\n\n    },\n    floor(className,op,f) {\n        return (\n            <select name=\"floor\" id={\"floor\"+op} className={ className } required onChange={f}>\n                <option value=\"0\">Select...</option>\n                { SearchOpions('floor',  '1',null) }\n                { SearchOpions('floor', '2',null) }\n                { SearchOpions('floor',  '3',null) }\n                { SearchOpions('floor',  '4',null) }\n            </select>\n        )\n    },\n    furniture(className,f) {\n        return (\n            <select name=\"furnished\" id=\"furnished\" className={ className } required onChange={f}>\n                <option value=\"0\">Select...</option>\n                { SearchOpions('furnished', 'Furnished',null) }\n                { SearchOpions('furnished',  'Part-furnished',null) }\n                { SearchOpions('furnished', 'Not furnished',null) }\n            </select>\n        )\n    },\n    heating(className, f) {\n        return (\n            <select name=\"heating\" id=\"heating\" className={ className } required onChange={f}>\n                <option value=\"0\">Select...</option>\n                { SearchOpions('heating', 'Gas', null) }\n                { SearchOpions('heating', 'Electricity', null) }\n                { SearchOpions('heating','Local', null) }\n            </select>\n        )\n    },\n}","D:\\WebProjects\\NewProps\\properties - Copy\\src\\components\\filterBar\\filter.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\services\\getData.js",["232"],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\components\\searchInputs\\index.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\components\\cards\\index.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\components\\searchBar\\index.js",["233","234","235"],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\components\\detailsComponent\\index.js",["236"],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\components\\cards\\card-elemtent.js",[],"D:\\WebProjects\\NewProps\\properties - Copy\\src\\components\\searchInputs\\price.js",["237"],"import React from 'react'\n\n\nexport default {\n\n\n    SellingPrice(minOrMax, classNeme, f) {\n\n        return (\n            <select name=\"price\" id={ minOrMax }  className={ classNeme } onChange={f}>\n                <option value=\"0\" selected>Alll</option>\n                <option value=\"10 000\">10 000</option>\n                <option value=\"20 000\">20 000</option>\n                <option value=\"30 000\">30 000</option>\n                <option value=\"40 000\">40 000</option>\n                <option value=\"50 000\">50 000</option>\n                <option value=\"60 000\">60 000</option>\n                <option value=\"70 000\">70 000</option>\n                <option value=\"80 000\">80 000</option>\n                <option value=\"90 000\">90 000</option>\n                <option value=\"100 000\">100 00</option>\n                <option value=\"110 000\">110 00</option>\n                <option value=\"120 000\">120 00</option>\n                <option value=\"130 000\">130 00</option>\n                <option value=\"140 000\">140 00</option>\n                <option value=\"150 000\">150 00</option>\n                <option value=\"160 000\">160 00</option>\n                <option value=\"200 000\">200 00</option>\n                <option value=\"210 000\">210 00</option>\n                <option value=\"220 000\">220 00</option>\n                <option value=\"230 000\">230 00</option>\n                <option value=\"240 000\">240 00</option>\n                <option value=\"250 000\">250 00</option>\n                <option value=\"260 000\">260 00</option>\n                <option value=\"270 000\">270 00</option>\n                <option value=\"280 000\">280 00</option>\n                <option value=\"290 000\">290 00</option>\n                <option value=\"350 000\">350 00</option>\n                <option value=\"400 000\">400 00</option>\n                <option value=\"450 000\">450 00</option>\n                <option value=\"500 000\">500 00</option>\n                <option value=\"550 000\">550 00</option>\n                <option value=\"550 000+\">550 00+</option>\n            </select>\n        )\n    },\n    RentingPrice(minOrMax, classNeme, f) {\n\n        return (\n            <select name=\"price\" id={ minOrMax } className={ classNeme } onChange={f}>\n                <option value=\"0\" selected>Alll</option>\n                <option value=\"100\">100</option>\n                <option value=\"200\">200</option>\n                <option value=\"300\">300</option>\n                <option value=\"400\">400</option>\n                <option value=\"500\">500</option>\n                <option value=\"600\">600</option>\n                <option value=\"700\">700</option>\n                <option value=\"800\">800</option>\n                <option value=\"900\">900</option>\n                <option value=\"1000\">1000</option>\n                <option value=\"1100\">1100</option>\n                <option value=\"1200\">1200</option>\n                <option value=\"13