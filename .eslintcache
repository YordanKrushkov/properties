     let item = properties[propertie]\r\n                    let key = propertie;\r\n                    return CardElement(item, key)\r\n                }\r\n                else if (filter === 'HOME') {\r\n                    let item = properties[propertie]\r\n                    let key = propertie;\r\n                    return CardElement(item, key)\r\n                } else {\r\n                    return\r\n                }\r\n            })\r\n        } else {\r\n            return <h1> No data</h1>\r\n        }\r\n    },\r\n \r\n\r\nasync getSingleProp(getProperties, id) {\r\n    const promise = await fetch(`https://properties-3e020-default-rtdb.firebaseio.com/properties/${id}.json`);\r\n    const properties = await promise.json();\r\n    getProperties(properties)\r\n}\r\n}","D:\\WebProjects\\NewProps\\properties\\src\\components\\formElements\\inputs.js",["111"],"import React from 'react'\r\nimport styles from './index.module.css'\r\n\r\n\r\n\r\nexport default {\r\n    InputElements(name, type, placeholder, text, f, req) {\r\n\r\n        return (\r\n            <div className={ styles.inputWrapper }>\r\n                <label className={ styles.inputLabel } htmlFor={ name }>{ text }</label>\r\n                {req ? <input className={ styles.input }  placeholder={ placeholder } type={ type } name={ name } id={ name } onChange={ f } required />\r\n                    : <input className={ styles.input }  placeholder={ placeholder } type={ type } name={ name } id={ name } onChange={ f } /> }\r\n            </div>\r\n        )\r\n    }, ButtonsField(className, type, id, name, text, f, req) {\r\n\r\n        return (\r\n            <div className={ className }>\r\n                {req ? <input className={ styles.inputTick }  required type={ type } name={ name } id={ id } onChange={ f } />\r\n                    : <input className={ styles.inputTick }  type={ type } name={ name } id={ id } onChange={ f } /> }\r\n                <label className={ styles.Label } htmlFor={ id }>{ text }</label>\r\n\r\n            </div>\r\n\r\n        )\r\n    },\r\n\r\n}\r\n","D:\\WebProjects\\NewProps\\properties\\src\\Pages\\DetailsPage\\index.js",["112","113"],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\Register\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\login\\index.js",["114","115"],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\Rent\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\HomePage\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\Sell\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\Pages\\SubmitForm\\post.js",["116"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\detailsComponent\\index.js",["117"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\cities.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\type.js",["118"],"import React from 'react'\r\nimport SearchOpions from './index'\r\n\r\nexport default {\r\n\r\n    TypeSelect(className, f) {\r\n\r\n        return (\r\n            <select name=\"type\" id=\"type\" className={ className }  onChange={f} required>\r\n                <option value=\"0\">Choose</option>\r\n                { SearchOpions('type',  'Flat', null) }\r\n                { SearchOpions('type', 'House', null) }\r\n                { SearchOpions('type', 'Cottage', null) }\r\n                { SearchOpions('type', 'Land', null) }\r\n            </select>\r\n        )\r\n    },\r\n\r\n    bedroomCount(className,f) {\r\n        return (\r\n            <select name=\"type\" id=\"bedrooms\" className={ className }  onChange={f} required>\r\n                <option value=\"0\">Choose</option>\r\n                { SearchOpions('bedrooms', 'studio', 'Studio', null) }\r\n                { SearchOpions('bedrooms', '1 bedroom', null) }\r\n                { SearchOpions('bedrooms', '2 bedroom', null) }\r\n                { SearchOpions('bedrooms', '3 bedroom',null ) }\r\n                { SearchOpions('bedrooms', '4 bedroom',null ) }\r\n            </select>\r\n        )\r\n\r\n    },\r\n    construction(className, f) {\r\n        return (\r\n            <select name=\"construction\" id=\"construction\" className={ className } required onChange={f}>\r\n                <option value=\"0\">Choose</option>\r\n                { SearchOpions('construction',  'New',null) }\r\n                { SearchOpions('construction', 'Old',null) }\r\n                { SearchOpions('construction', 'Brick',null) }\r\n                { SearchOpions('construction', 'Panel',null) }\r\n            </select>\r\n        )\r\n\r\n    },\r\n    floor(className,op,f) {\r\n        return (\r\n            <select name=\"floor\" id={\"floor\"+op} className={ className } required onChange={f}>\r\n                <option value=\"0\">Choose</option>\r\n                { SearchOpions('floor',  '1',null) }\r\n                { SearchOpions('floor', '2',null) }\r\n                { SearchOpions('floor',  '3',null) }\r\n                { SearchOpions('floor',  '4',null) }\r\n            </select>\r\n        )\r\n    },\r\n    furniture(className,f) {\r\n        return (\r\n            <select name=\"furnished\" id=\"furnished\" className={ className } required onChange={f}>\r\n                <option value=\"0\">Choose</option>\r\n                { SearchOpions('furnished', 'Furnished',null) }\r\n                { SearchOpions('furnished',  'Part-furnished',null) }\r\n                { SearchOpions('furnished', 'Not furnished',null) }\r\n            </select>\r\n        )\r\n    },\r\n    heating(className, f) {\r\n        return (\r\n            <select name=\"heating\" id=\"heating\" className={ className } required onChange={f}>\r\n                <option value=\"0\">Choose</option>\r\n                { SearchOpions('heating', 'Gas', null) }\r\n                { SearchOpions('heating', 'Electricity', null) }\r\n                { SearchOpions('heating','Local', null) }\r\n    