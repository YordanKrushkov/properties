ata.idToken}`\r\n                history.push('/')\r\n            })\r\n            .catch((e) => {\r\n                console.log(e);\r\n            })\r\n    }\r\n\r\n    return (\r\n        <div className={ styles.container }>\r\n            <h1 className={ styles.name }>Sign in</h1>\r\n            <p>Sign in to save your favourite properties, searches, house prices and more.</p>\r\n            <form action=\"\" className={ styles.formBody } onSubmit={ submitHandler }>\r\n                <label htmlFor=\"email\">Email</label>\r\n                <input type=\"email\" name=\"\" id=\"email\" onChange={ chnageHendler } />\r\n                <label htmlFor=\"password\">Password</label>\r\n                <input type=\"password\" name=\"\" id=\"password\" onChange={ chnageHendler } />\r\n                <button>Login</button>\r\n            </form>\r\n            <a href=\"#\" className={ styles.link }>Forgot your password?</a>\r\n            <div className={ styles.register }>\r\n                <div className={ styles.joinUs }> <p>You don't have an accout yet? </p>\r\n                    <Link to=\"/register\">Join us now</Link>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\nexport default Login","D:\\WebProjects\\NewProps\\properties\\src\\components\\main\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Header\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Rent\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Sell\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Register\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\cards\\card-elemtent.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\cards\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchBar\\index.js",["102","103","104"],"D:\\WebProjects\\NewProps\\properties\\src\\services\\getData.js",["105"],"import CardElement from \".