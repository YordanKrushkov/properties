ngCount":0,"source":null},{"filePath":"89","messages":"90","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"48"},{"filePath":"91","messages":"92","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"93","usedDeprecatedRules":"48"},"D:\\WebProjects\\NewProps\\properties\\src\\index.js",[],["94","95"],"D:\\WebProjects\\NewProps\\properties\\src\\reportWebVitals.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\App.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\useState.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\Context.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\form\\post.js",["96","97","98","99","100"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\login\\index.js",["101"],"import React, { useState, useContext } from 'react';\r\nimport styles from './index.module.css'\r\nimport { Link, useHistory } from 'react-router-dom'\r\nimport UserContext from '../../Context';\r\nconst apiKey = 'AIzaSyBFr1QW_fF9sluMRPfYk6UzMgoOAxlFC0I'\r\nconst url = `https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=${apiKey}`\r\n\r\nconst Login = () => {\r\n    const [user, getUser] = useState({\r\n        email: '',\r\n        password: ''\r\n    })\r\n    const context = useContext(UserContext);\r\n    const history = useHistory();\r\n    const chnageHendler = (e) => {\r\n        getUser({\r\n            [e.target.id]: e.target.value\r\n        })\r\n    }\r\n    const submitHandler = (e) => {\r\n        e.preventDefault();\r\n        const { email, password } = user;\r\n\r\n        fetch(url, {\r\n            method: 'POST',\r\n            headers: { 'Content-Type': 'application/json' },\r\n            body: JSON.stringify({ email, password })\r\n        }).then(res => res.json())\r\n            .then(data => {\r\n                context.logIn(data.username, data.email)\r\n                localStorage.setItem(\"user\", data.email)\r\n                document.cookie = `x-auth-token=${data.idToken}`\r\n                history.push('/')\r\n            })\r\n            .catch((e) => {\r\n                console.log(e);\r\n            })\r\n    }\r\n\r\n    return (\r\n        <div className={ styles.container }>\r\n            <h1 className={ styles.name }>Sign in</h1>\r\n            <p>Sign in to save your favourite properties, searches, house prices and more.</p>\r\n            <form action=\"\" className={ styles.formBody } onSubmit={ submitHandler }>\r\n                <label htmlFor=\"email\">Email</label>\r\n                <input type=\"email\" name=\"\" id=\"email\" onChange={ chnageHendler } />\r\n                <label htmlFor=\"password\">Password</label>\r\n                <input type=\"password\" name=\"\" id=\"password\" onChange={ chnageHendler } />\r\n                <button>Login</button>\r\n            </form>\r\n            <a href=\"#\" className={ styles.link }>Forgot your password?</a>\r\n            <div className={ styles.register }>\r\n                <div className={ styles.joinUs }> <p>You don't have an accout yet? </p>\r\n                    <Link to=\"/register\">Join us now</Link>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\nexport default Login","D:\\WebProjects\\NewProps\\properties\\src\\components\\main\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Header\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Rent\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Sell\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Register\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\cards\\card-elemtent.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\cards\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchBar\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\services\\getData.js",["102"],"import CardElement from \"../components/cards/card-elemtent\";\r\n\r\nexport default {\r\n     async getData(getProperties){\r\n        const promise = await fetch('https://properties-3e020-default-rtdb.firebaseio.com/properties.json');\r\n        const properties = await promise.json();\r\n        getProperties(properties)\r\n    },\r\n    renderProperties (properties,filter){\r\n        return Object.keys(properties).map((propertie) => {\r\n            if (properties[propertie].hasOwnProperty(filter)) {\r\n                let item = properties[propertie]\r\n                let key = propertie;\r\n                return CardElement(item, key)\r\n            }else{\r\n                let item = properties[propertie]\r\n                let key = propertie;\r\n                return CardElement(item, key)\r\n            }\r\n        })\r\n    }\r\n}","D:\\WebProjects\\NewProps\\properties\\src\\components\\singleCard\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\cities.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\index.js",["103"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\type.js",["104"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\price.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\formElements\\inputs.js",["105"],"import React from 'react'\r\nimport styles from './index.module.css'\r\n\r\n\r\n\r\nexport default {\r\n    InputElements(name, type, placeholder, text, f, req) {\r\n\r\n        return (\r\n            <div className={ styles.inputWrapper }>\r\n            <label className={ styles.inputLabel } htmlFor={ name }>{ text }</label>\r\n            {req ?<input className={ styles.input } placeholder={ placeholder } type={ type } name={ name } id={ name } onChange={f} required/>\r\n                :<input className={ styles.input } placeholder={ placeholder } type={ type } name={ name } id={ name } onChange={f}/>}\r\n            </div>\r\n        )\r\n    }, ButtonsField(className, type, id, name, text,f,req ) {\r\n\r\n        return (\r\n            <div className={ className}>\r\n                {req ? <input className={ styles.inputTick } required type={ type } name={ name } id={ id } onChange={f}/>\r\n                    : <input className={ styles.inputTick } type={ type } name={ name } id={ id } onChange={f} /> }\r\n                <label className={ styles.Label } htmlFor={ id }>{ text }</label>\r\n\r\n            </div>\r\n\r\n        )\r\n    },\r\n\r\n}\r\n",{"ruleId":"106","replacedBy":"107"},{"ruleId":"108","replacedBy":"109"},{"ruleId":"110","severity":1,"message":"111","line":31,"column":11,"nodeType":"112","messageId":"113","endLine":31,"endColumn":18},{"ruleId":"110","severity":1,"message":"114","line":32,"column":12,"nodeType":"112","messageId":"113","endLine":32,"endColumn":15},{"ruleId":"110","severity":1,"message":"115","line":37,"column":13,"nodeType":"112","messageId":"113","endLine":37,"endColumn":16},{"ruleId":"116","severity":1,"message":"117","line":216,"column":1,"nodeType":"118","messageId":"119","endLine":219,"endColumn":78},{"ruleId":"116","severity":1,"message":"117","line":221,"column":1,"nodeType":"118","messageId":"119","endLine":225,"endColumn":88},{"ruleId":"120","severity":1,"message":"121","line":51,"column":13,"nodeType":"122","endLine":51,"endColumn":51},{"ruleId":"123","severity":1,"message":"124","line":3,"column":1,"nodeType":"125","endLine":22,"endColumn":2},{"ruleId":"110","severity":1,"message":"126","line":2,"column":8,"nodeType":"112","messageId":"113","endLine":2,"endColumn":14},{"ruleId":"123","severity":1,"message":"124","line":4,"column":1,"nodeType":"125","endLine":75,"endColumn":2},{"ruleId":"123","severity":1,"message":"124","line":6,"column":1,"nodeType":"125","endLine":29,"endColumn":2},"no-native-reassign",["127"],"no-negated-in-lhs",["128"],"no-unused-vars","'history' is assigned a value but never used.","Identifier"