\index.js",["86"],"import React, { useState, useContext } from 'react';\r\nimport styles from './index.module.css'\r\nimport { Link, useHistory } from 'react-router-dom'\r\nimport UserContext from '../../Context';\r\nconst apiKey = 'AIzaSyBFr1QW_fF9sluMRPfYk6UzMgoOAxlFC0I'\r\nconst url = `https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=${apiKey}`\r\n\r\nconst Login = () => {\r\n    const [user, getUser] = useState({\r\n        email: '',\r\n        password: ''\r\n    })\r\n    const context = useContext(UserContext);\r\n    const history = useHistory();\r\n    const chnageHendler = (e) => {\r\n        getUser({\r\n            [e.target.id]: e.target.value\r\n        })\r\n    }\r\n    const submitHandler = (e) => {\r\n        e.preventDefault();\r\n        const { email, password } = user;\r\n\r\n        fetch(url, {\r\n            method: 'POST',\r\n            headers: { 'Content-Type': 'application/json' },\r\n            body: JSON.stringify({ email, password })\r\n        }).then(res => res.json())\r\n            .then(data => {\r\n                context.logIn(data.username, data.email)\r\n                localStorage.setItem(\"user\", data.email)\r\n                document.cookie = `x-auth-token=${data.idToken}`\r\n                history.push('/')\r\n            })\r\n            .catch((e) => {\r\n                console.log(e);\r\n            })\r\n    }\r\n\r\n    return (\r\n        <div className={ styles.container }>\r\n            <h1 className={ styles.name }>Sign in</h1>\r\n            <p>Sign in to save your favourite properties, searches, house prices and more.</p>\r\n            <form action=\"\" className={ styles.formBody } onSubmit={ submitHandler }>\r\n                <label htmlFor=\"email\">Email</label>\r\n                <input type=\"email\" name=\"\" id=\"email\" onChange={ chnageHendler } />\r\n                <label htmlFor=\"password\">Password</label>\r\n                <input type=\"password\" name=\"\" id=\"password\" onChange={ chnageHendler } />\r\n                <button>Login</button>\r\n            </form>\r\n            <a href=\"#\" className={ styles.link }>Forgot your password?</a>\r\n            <div className={ styles.register }>\r\n                <div className={ styles.joinUs }> <p>You don't have an accout yet? </p>\r\n                    <Link to=\"/register\">Join us now</Link>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\nexport default Login","D:\\WebProjects\\NewProps\\properties\\src\\components\\main\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Header\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Rent\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Sell\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\Register\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\cards\\card-elemtent.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\cards\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchBar\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\services\\getData.js",["87"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\singleCard\\index.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\cities.js",[],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\index.js",["88"],"D:\\WebProjects\\NewProps\\properties\\src\\components\\searchInputs\\price.js",[],{"ruleId":"89","replacedBy":"90"},{"ruleId":"91","replacedBy":"92"},{"ruleId":"93","severity":1,"message":"94","line":51,"column":13,"nodeType":"95","endLine":51,"endColumn":51},{"ruleId":"96","severity":1,"message":"97","line":3,"column":1,"nodeType":"98","endLine":22,"endColumn":2},{"ruleId":"99","severity":1,"message":"100","line":2,"column":8,"nodeType":"101","messageId":"102","endLine":2,"endColumn":14},"no-native-reassign",["103"],"no-negated-in-lhs",["104"],"jsx-a11y/anchor-is-valid","The href attribute requires a valid value to be accessible. Provide a valid, navigable address as the href value. If you cannot provide a valid href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/evcohen/eslint-plugin-jsx-a11y/blob/master/docs/rules/anchor-is-valid.md","JSXOpeningElement","import/no-anonymous-default-export","Assign object to a variable before exporting as module default","ExportDefaultDeclaration","no-unused-vars","'styles' is defined but never used.","Identifier","unusedVar","no-global-assign","no-unsafe-negation"]