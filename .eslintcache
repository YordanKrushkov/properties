on>\r\n                <option value=\"money\">1100</option>\r\n                <option value=\"money\">1200</option>\r\n                <option value=\"money\">1300</option>\r\n                <option value=\"money\">1400</option>\r\n                <option value=\"money\">1500</option>\r\n                <option value=\"money\">1600</option>\r\n                <option value=\"money\">2000</option>\r\n                <option value=\"money\">2100</option>\r\n                <option value=\"money\">2200</option>\r\n                <option value=\"money\">2300</option>\r\n                <option value=\"money\">2400</option>\r\n                <option value=\"money\">2500</option>\r\n                <option value=\"money\">2600</option>\r\n                <option value=\"money\">2700</option>\r\n                <option value=\"money\">2800</option>\r\n                <option value=\"money\">2900</option>\r\n                <option value=\"money\">3000</option>\r\n            </select>\r\n        )\r\n    }\r\n\r\n}","D:\\WebProjects\\NewProps\\properties\\src\\components\\formElements\\inputs.js",["111"],"import React from 'react'\r\nimport styles from './index.module.css'\r\n\r\n\r\n\r\nexport default {\r\n    InputElements(name, type, placeholder, text, f, req) {\r\n\r\n        return (\r\n            <div className={ styles.inputWrapper }>\r\n                <label className={ styles.inputLabel } htmlFor={ name }>{ text }</label>\r\n                {req ? <input className={ styles.input }  placeholder={ placeholder } type={ type } name={ name } id={ name } onChange={ f } required />\r\n                    : <input className={ styles.input }  placeholder={ placeholder } type={ type } name={ name } id={ name } onChange={ f } /> }\r\n            </div>\r\n        )\r\n    }, ButtonsField(className, type, id, name, text, f, req) {\r\n\r\n        return (\r\n            <div className={ className }>\r\n                {req ? <input className={ styles.inputTick }  required type={ type } name={ name } id={ id } onChange={ f } />\r\n                    : <input className={ styles.inputTick }  type={ type } name={ name } id={ id } onChange={ f } /> }\r\n                <label className={ styles.Label } htmlFor={ id }>{ text }</label>\r\n\r\n            </div>\r\n\r\n        )\r\n    },\r\n\r\n}\r\n",{"ruleId":"112","replacedBy":"113"},{"ruleId":"114","replacedBy":"115"},{"ruleId":"116","severity":1,"message":"117","line":9,"column":26,"nodeType":"118","messageId":"119","endLine":9,"endColumn":34},{"ruleId":"120","severity":1,"message":"121","line":51,"column":13,"nodeType":"122","endLine":51,"endColumn":51},{"ruleId":"123","severity":1,"message":"124","line":3,"column":1,"nodeType":"125","endLine":34,"endColumn":2},{"ruleId":"126","severity":1,"message":"127","line":22,"column":21,"nodeType":"128","messageId":"129","endLine":22,"endColumn":27},{"ruleId":"116","severity":1,"message":"130","line":10,"column":12,"nodeType":"118","messageId":"119","endLine":10,"endColumn":17},{"ruleId":"116","severity":1,"message":"131","line":10,"column":19,"nodeType":"118","messageId":"119","endLine":10,"endColumn":30},{"ruleId":"132","severity":1,"message":"133","line":15,"column":8,"nodeType":"134","endLine":15,"endColumn":10,"suggestions":"135"},{"ruleId":"116","severity":1,"message":"136","line":20,"column":9,"nodeType":"118","messageId":"119","endLine":20,"endColumn":13},{"ruleId":"116","severity":1,"message":"137","line":2,"column":8,"nodeType":"118","messageId":"119","endLine":2,"endColumn":14},{"ruleId":"123","severity":1,"message":"124","line":4,"column":1,"nodeType":"125","endLine":75,"endColumn":2},{"ruleId":"123","severity":1,"message":"124","line":4,"column":1,"nodeType":"125","endLine":83,"endColumn":2},{"ruleId":"123","severity":1,"message":"124","line":6,"column":1,"nodeType":"125","endLine":29,"endColumn":2},"no-native-reassign",["138"],"no-negated-in-lhs",["139"],"no-unused-vars","'getState' is assigned a value but never used.","Identifier","unusedVar","jsx-a11y/anchor-is-valid","The href attribute requires a valid value to be accessible. Provide a valid, navigable address as the href value. If you cannot provide a valid href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/evcohen/eslint-plugin-jsx-a11y/blob/master/docs/rules/anchor-is-valid.md","JSXOpeningElement","import/no-anonymous-default-export","Assign object to a variable before exporting as module default","ExportDefaultDeclaration","array-callback-return","Array.prototype.map() expects a return value from arrow function.","ReturnStatement","expectedReturnValue","'first' is assigned a value but never used.","'changeFitst' is assigned a value but never used.","react-hooks/exhaustive-deps","React Hook useEffect has a missing dependency: 'id'. Either include it or remove the dependency array.","ArrayExpression",["140"],"'char' is assigned a value but never used.","'styles' is defined but never used.","no-global-assign","no-unsafe-negation",{"desc":"141","fix":"142"},"Update the dependencies array to be: [id]",{"range":"143","text":"144"},[586,588],"[id]"]